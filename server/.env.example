# =======================================================
# Beehive IoT - Configurazione Server
# =======================================================
# Copia questo file in .env e imposta valori reali e sicuri.
# IMPORTANTE: Non committare mai .env nel repository!
#
# Primo avvio:
#   cp .env.example .env
#   # Modifica .env con password sicure
#   make start
# =======================================================

# --- PostgreSQL ---
# Password del database PostgreSQL
POSTGRES_PASSWORD=imposta_password_sicura_qui

# --- MQTT Broker ---
# Username e password per il broker Mosquitto
MQTT_USER=beehive
MQTT_PASSWORD=imposta_password_sicura_qui

# --- Utenti applicazione ---
# Password per l'utente admin (admin@beehive.local), creato al primo avvio
ADMIN_PASSWORD=imposta_password_sicura_admin

# Password per l'utente demo (utente@test.local), creato al primo avvio
USER_PASSWORD=imposta_password_sicura_utente

# --- JWT ---
# Chiave segreta per la firma dei token JWT.
# Genera con:  openssl rand -hex 32
JWT_SECRET_KEY=genera_con_openssl_rand_hex_32
